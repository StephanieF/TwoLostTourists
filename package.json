{
	"name": "next",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"generate-content": "node scripts/generate-content-index.mjs",
		"dev": "npm run generate-content && next dev --turbopack",
		"build": "npm run generate-content && next build",
		"start": "next start",
		"lint": "next lint",
		"deploy": "npm run generate-content && opennextjs-cloudflare build && opennextjs-cloudflare deploy",
		"upload": "npm run generate-content && opennextjs-cloudflare build && opennextjs-cloudflare upload",
		"preview": "npm run generate-content && opennextjs-cloudflare build && opennextjs-cloudflare preview",
		"cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts",
		"sync-content": "node scripts/sync-content.mjs"
	},
	"dependencies": {
		"@mdx-js/loader": "^3.1.1",
		"@mdx-js/react": "^3.1.1",
		"@next/mdx": "^16.2.10",
		"@opennextjs/cloudflare": "^1.11.0",
		"@types/mdx": "^2.0.14",
		"gray-matter": "^4.0.3",
		"next": "^16.2.7",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"remark-frontmatter": "^5.0.0",
		"remark-gfm": "^4.0.1"
	},
	"devDependencies": {
		"@eslint/eslintrc": "^3",
		"@tailwindcss/postcss": "^4",
		"@tailwindcss/typography": "^0.5.20",
		"@types/node": "^25.9.2",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"eslint": "^9.39.4",
		"eslint-config-next": "^16.2.7",
		"tailwindcss": "^4",
		"typescript": "^6.0.3",
		"wrangler": "^4.50.0"
	}
}
